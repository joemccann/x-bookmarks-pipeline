# X Bookmarks Pipeline (Rust)
# Copy this file to .env and fill values.

# Required LLM keys
CEREBRAS_API_KEY=your_cerebras_api_key_here
XAI_API_KEY=your_xai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional model overrides
# CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507
# XAI_MODEL=grok-4-0709
# ANTHROPIC_MODEL=claude-opus-4-6
# OPENAI_MODEL=gpt-5.4

# Timeout / runtime config
# API_TIMEOUT=120
# VISION_TIMEOUT=60
# FETCH_TIMEOUT=30
# MAX_WORKERS=5
# OUTPUT_DIR=output
# CACHE_PATH=cache/bookmarks.db
# DEFAULT_TICKER=BTCUSDT
# DEFAULT_TIMEFRAME=D

# SMTP notifications (used by rust/src/notify.rs)
# Optional SMTP notifications
# SMTP_HOST=smtp.example.com
# SMTP_USER=you@example.com
# SMTP_PASSWORD=your_password_or_app_password
# SMTP_FROM=pipeline@example.com
# SMTP_TO=alerts@example.com
