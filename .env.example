# X Bookmarks Pipeline
# Copy this file to .env and fill values.

# Required LLM keys
CEREBRAS_API_KEY=csk-...
XAI_API_KEY=xai-...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# X API auth for bookmark fetching
# Preferred: use one of these as a bearer token
X_BEARER_TOKEN=...
# Alternate accepted env vars:
# X_ACCESS_TOKEN=...
# XPB_X_BEARER_TOKEN=...
# XPB_X_ACCESS_TOKEN=...

# Fetch target: numeric ID (preferred) or username
X_FETCH_USER_ID=14814762
# X_FETCH_USERNAME=joemccann

# Optional OAuth refresh fields used by automatic token refresh
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REFRESH_TOKEN=
X_OAUTH_SCOPE="tweet.read users.read bookmark.read offline.access"
# Optional browser-reauth fields
# X_REDIRECT_URI=http://localhost:8765/callback
# XPB_X_CLIENT_ID=
# XPB_X_CLIENT_SECRET=
# XPB_X_REFRESH_TOKEN=
X_USER_ID=

# SMTP notifications (used by src/notify.rs)
SMTP_HOST=smtp.gmail.com
SMTP_USER=you@example.com
SMTP_PASS=app_password_or_token
SMTP_PASSWORD=
SMTP_FROM=you@example.com
SMTP_TO=alerts@example.com

# Optional config overrides
# CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507
# XAI_MODEL=grok-4-0709
# ANTHROPIC_MODEL=claude-opus-4-6
# OPENAI_MODEL=gpt-5.4
# API_TIMEOUT=120
# VISION_TIMEOUT=60
# FETCH_TIMEOUT=30
# MAX_WORKERS=5
# OUTPUT_DIR=output
# CACHE_PATH=cache/bookmarks.db
# DEFAULT_TICKER=BTCUSDT
# DEFAULT_TIMEFRAME=D

# Daemon behavior
# XPB_DAEMON=true
# XPB_DAEMON_INTERVAL_SECONDS=300
# XPB_DAEMON_MAX_CYCLES=0
# DAEMON_MODE=true
# XPB_FETCH_LOOP=true
