# ============================================================
# x-bookmarks-pipeline environment variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── xAI (required) ──────────────────────────────────────────
# Get your API key at: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# ── X / Twitter API (required for --fetch mode) ─────────────
# OAuth 2.0 user access token with scopes:
#   bookmark.read  tweet.read  users.read
#
# How to get one:
#   1. Create a project at https://console.x.com/
#   2. Enable OAuth 2.0, add scopes: bookmark.read tweet.read users.read
#   3. Generate a user access token via the OAuth 2.0 PKCE flow
X_USER_ACCESS_TOKEN=your_x_user_access_token_here

# Your numeric X user ID (NOT your @username).
# Find it by running:
#   curl -H "Authorization: Bearer <X_USER_ACCESS_TOKEN>" \
#        "https://api.twitter.com/2/users/me"
# Or just pass --x-username <handle> on the CLI and the app resolves it.
X_USER_ID=your_numeric_x_user_id_here

# ── Anthropic (required for strategy planning) ────────────
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OpenAI (required for Pine Script generation) ──────────
# Get your API key at: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
